{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.0.0/schema.json",
  "name": "visual065",
  "position": {
    "x": 650,
    "y": 150,
    "z": 65000,
    "height": 250,
    "width": 610,
    "tabOrder": 65000
  },
  "visual": {
    "visualType": "clusteredBarChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "focus_dim_account"
                    }
                  },
                  "Property": "account_name"
                }
              },
              "queryRef": "focus_dim_account.account_name",
              "nativeQueryRef": "account_name",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Cloud Exception $"
                }
              },
              "queryRef": "_Measures.Cloud Exception $",
              "nativeQueryRef": "Cloud Exception $"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true,
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Exception dollars by cloud account'"
                }
              }
            },
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ]
    }
  }
}